{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Siga Crédito — Design Tokens (Figma-ready). Source: design_system/DESIGN.md v1.0",
  "color": {
    "brand": {
      "red":      { "$value": "#C01920", "$type": "color", "$description": "Primária institucional — selos, links, ícones-chave" },
      "redDeep":  { "$value": "#8E1218", "$type": "color", "$description": "Hover/pressed do vermelho" },
      "redSoft":  { "$value": "#F7E5E6", "$type": "color", "$description": "Fundo de aviso institucional" },
      "ink":      { "$value": "#1E1E1F", "$type": "color", "$description": "Preto da marca — texto e headlines" },
      "stone":    { "$value": "#ADBBC8", "$type": "color", "$description": "Cinza-azulado — divisores, ilustrações" },
      "cream":    { "$value": "#F0E4CC", "$type": "color", "$description": "Creme — fundos calmos, blocos de descanso" }
    },
    "cta": {
      "green":     { "$value": "#1FAA59", "$type": "color", "$description": "Verde WhatsApp — exclusivo do CTA principal" },
      "greenDeep": { "$value": "#178A48", "$type": "color" },
      "greenSoft": { "$value": "#E4F5EC", "$type": "color", "$description": "Halo / focus ring" }
    },
    "neutral": {
      "bg":           { "$value": "#FBF8F3", "$type": "color", "$description": "Background base — branco-creme" },
      "surface":      { "$value": "#FFFFFF", "$type": "color" },
      "surface2":     { "$value": "#F4EEDF", "$type": "color", "$description": "Seções alternadas (ritmo)" },
      "surfaceInk":   { "$value": "#14110E", "$type": "color", "$description": "Fundo escuro institucional, quente" },
      "border":       { "$value": "#E6DFCF", "$type": "color" },
      "borderStrong": { "$value": "#C9BFA8", "$type": "color" }
    },
    "text": {
      "default":  { "$value": "#1E1E1F", "$type": "color" },
      "muted":    { "$value": "#5A554C", "$type": "color" },
      "subtle":   { "$value": "#8B8579", "$type": "color" },
      "onDark":   { "$value": "#FBF8F3", "$type": "color" },
      "onRed":    { "$value": "#FFFFFF", "$type": "color" },
      "onGreen":  { "$value": "#FFFFFF", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#1FAA59", "$type": "color" },
      "warning": { "$value": "#B8770E", "$type": "color", "$description": "Âmbar amadeirado — não amarelo gritante" },
      "danger":  { "$value": "#B23A2A", "$type": "color", "$description": "Terracota — não vermelho de pânico" },
      "info":    { "$value": "#2F6E8F", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "display": { "$value": "Geist", "$type": "fontFamily" },
      "text":    { "$value": "General Sans", "$type": "fontFamily" },
      "mono":    { "$value": "JetBrains Mono", "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "display": { "$value": "clamp(2.5rem, 6vw, 4.5rem)", "$type": "dimension" },
      "h1":      { "$value": "clamp(2rem, 4.5vw, 3.25rem)", "$type": "dimension" },
      "h2":      { "$value": "clamp(1.625rem, 3vw, 2.25rem)", "$type": "dimension" },
      "h3":      { "$value": "1.5rem", "$type": "dimension" },
      "h4":      { "$value": "1.25rem", "$type": "dimension" },
      "h5":      { "$value": "1.125rem", "$type": "dimension" },
      "h6":      { "$value": "1rem", "$type": "dimension" },
      "lead":    { "$value": "1.1875rem", "$type": "dimension" },
      "body":    { "$value": "1.0625rem", "$type": "dimension" },
      "small":   { "$value": "0.9375rem", "$type": "dimension" },
      "caption": { "$value": "0.8125rem", "$type": "dimension" },
      "label":   { "$value": "0.75rem",   "$type": "dimension" }
    },
    "lineHeight": {
      "tight": { "$value": 1.05, "$type": "number" },
      "snug":  { "$value": 1.2,  "$type": "number" },
      "body":  { "$value": 1.65, "$type": "number" },
      "loose": { "$value": 1.75, "$type": "number" }
    },
    "letterSpacing": {
      "tight":  { "$value": "-0.025em", "$type": "dimension" },
      "snug":   { "$value": "-0.01em",  "$type": "dimension" },
      "normal": { "$value": "0",        "$type": "dimension" },
      "wide":   { "$value": "0.08em",   "$type": "dimension" }
    }
  },
  "spacing": {
    "s1":  { "$value": "4px",   "$type": "dimension" },
    "s2":  { "$value": "8px",   "$type": "dimension" },
    "s3":  { "$value": "12px",  "$type": "dimension" },
    "s4":  { "$value": "16px",  "$type": "dimension" },
    "s5":  { "$value": "20px",  "$type": "dimension" },
    "s6":  { "$value": "24px",  "$type": "dimension" },
    "s8":  { "$value": "32px",  "$type": "dimension" },
    "s10": { "$value": "40px",  "$type": "dimension" },
    "s12": { "$value": "48px",  "$type": "dimension" },
    "s16": { "$value": "64px",  "$type": "dimension" },
    "s20": { "$value": "80px",  "$type": "dimension" },
    "s24": { "$value": "96px",  "$type": "dimension" },
    "s32": { "$value": "128px", "$type": "dimension" }
  },
  "layout": {
    "container":     { "$value": "1280px", "$type": "dimension" },
    "containerPad":  { "$value": "clamp(20px, 5vw, 56px)", "$type": "dimension" },
    "sectionYSm":    { "$value": "clamp(48px, 8vw, 80px)",   "$type": "dimension" },
    "sectionYMd":    { "$value": "clamp(64px, 10vw, 112px)", "$type": "dimension" },
    "sectionYLg":    { "$value": "clamp(80px, 12vw, 144px)", "$type": "dimension" },
    "gridGap":       { "$value": "clamp(16px, 2vw, 32px)",   "$type": "dimension" }
  },
  "radius": {
    "sm":   { "$value": "6px",   "$type": "dimension" },
    "md":   { "$value": "10px",  "$type": "dimension" },
    "lg":   { "$value": "18px",  "$type": "dimension" },
    "full": { "$value": "999px", "$type": "dimension" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px rgba(30,18,18,.04), 0 2px 6px rgba(192,25,32,.04)",   "$type": "shadow" },
    "md": { "$value": "0 4px 8px rgba(30,18,18,.05), 0 12px 24px rgba(192,25,32,.06)", "$type": "shadow" },
    "lg": { "$value": "0 8px 16px rgba(30,18,18,.06), 0 24px 48px rgba(192,25,32,.08)","$type": "shadow" },
    "xl": { "$value": "0 12px 24px rgba(30,18,18,.08), 0 32px 64px rgba(31,170,89,.18)","$type": "shadow", "$description": "Exclusivo do FAB WhatsApp" }
  },
  "motion": {
    "duration": {
      "fast": { "$value": "80ms",  "$type": "duration" },
      "base": { "$value": "220ms", "$type": "duration" },
      "slow": { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(.2,.7,.2,1)", "$type": "cubicBezier" }
    }
  },
  "icon": {
    "size": {
      "sm": { "$value": "16px", "$type": "dimension" },
      "md": { "$value": "20px", "$type": "dimension" },
      "lg": { "$value": "24px", "$type": "dimension" },
      "xl": { "$value": "32px", "$type": "dimension" }
    },
    "strokeWidth": { "$value": 1.75, "$type": "number" },
    "library":     { "$value": "lucide", "$type": "other" }
  },
  "breakpoint": {
    "sm":  { "$value": "640px",  "$type": "dimension" },
    "md":  { "$value": "768px",  "$type": "dimension" },
    "lg":  { "$value": "1024px", "$type": "dimension" },
    "xl":  { "$value": "1280px", "$type": "dimension" },
    "2xl": { "$value": "1536px", "$type": "dimension" }
  }
}
